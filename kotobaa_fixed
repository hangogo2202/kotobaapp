    /* ── SYSTEM APP ARCHITECTURE STATE ── */
    let currentTab = 'home';
    let studyIndex = 0;
    let learntIds = [];
    let savedWordRelations = []; 
    let MY_VOCAB_PAGES = [];
    let currentVocabPageId = null;
    let NOTES = [];
    let isEditingNotebookTitle = false; // Persistent page header state modifier

    const id = x => document.getElementById(x);

    /* ── RUN INITIAL ENGINE STATE ── */
    function loadState() {
      try {
        learntIds = JSON.parse(localStorage.getItem('jlpt_learntIds')) || [];
        savedWordRelations = JSON.parse(localStorage.getItem('jlpt_savedWordRelations')) || [];
        MY_VOCAB_PAGES = JSON.parse(localStorage.getItem('jlpt_MY_VOCAB_PAGES')) || [
          { id: 'p1', title: '名詞 Noun Collection - Bài 1' },
          { id: 'p2', title: 'Weak Grammar Target Items' }
        ];
        NOTES = JSON.parse(localStorage.getItem('jlpt_NOTES')) || [];
        
        if (MY_VOCAB_PAGES.length > 0 && !currentVocabPageId) {
          currentVocabPageId = MY_VOCAB_PAGES[0].id;
        }
      } catch(e) {
        console.error("Local Storage configuration mismatch reset", e);
      }
      updateStats();
    }

    function saveState() { localStorage.setItem('jlpt_learntIds', JSON.stringify(learntIds)); updateStats(); }
    function saveRelations() { localStorage.setItem('jlpt_savedWordRelations', JSON.stringify(savedWordRelations)); updateStats(); }
    function savePages() { localStorage.setItem('jlpt_MY_VOCAB_PAGES', JSON.stringify(MY_VOCAB_PAGES)); }
    function saveNotes() { localStorage.setItem('jlpt_NOTES', JSON.stringify(NOTES)); }

    function updateStats() {
      id('stat-total-cards').textContent = VOCAB.length;
      id('stat-learnt-cards').textContent = learntIds.length;
      id('stat-saved-words').textContent = savedWordRelations.length;
    }

    /* ── NAVIGATION CORE TAB SWITCHER ── */
    function switchTab(t) {
      currentTab = t;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-view').forEach(v => v.style.display = 'none');
      
      const targetBtn = id(`tab-${t}`);
      if (targetBtn) targetBtn.classList.add('active');
      
      const targetView = id(`view-${t}`);
      if (targetView) targetView.style.display = 'block';
      
      if (t === 'study') renderStudyCard();
      if (t === 'dict') searchDict();
      if (t === 'myvocab') {
        isEditingNotebookTitle = false; // Ensure it returns clean
        renderMyVocab();
      }
      updateStats();
    }

    /* ── ACTIVE STUDY DECK CONTROLLER ── */
    function renderStudyCard() {
      if (!VOCAB.length) return;
      const card = VOCAB[studyIndex];
      id('fc-kanji').textContent = card.kanji;
      id('fc-reading').textContent = card.reading;
      id('fc-meaning').textContent = card.meaning;
      id('fc-pos').textContent = card.pos;
      id('flashcard-element').classList.remove('flipped');
      
      const fillPerc = ((studyIndex + 1) / VOCAB.length) * 100;
      id('study-progress-fill').style.width = `${fillPerc}%`;
      id('study-progress-lbl').textContent = `Card ${studyIndex + 1} of ${VOCAB.length}`;
      
      const totalMasteredPerc = Math.round((learntIds.length / VOCAB.length) * 100);
      id('study-percent-lbl').textContent = `${totalMasteredPerc}% Mastered`;
    }

    function flip() { id('flashcard-element').classList.toggle('flipped'); }
    function next() { studyIndex = (studyIndex + 1) % VOCAB.length; renderStudyCard(); }
    function prev() { studyIndex = (studyIndex - 1 + VOCAB.length) % VOCAB.length; renderStudyCard(); }
    
    function markLearnt() {
      const card = VOCAB[studyIndex];
      if (!learntIds.includes(card.id)) learntIds.push(card.id);
      saveState(); next();
    }
    function markHard() {
      const card = VOCAB[studyIndex];
      learntIds = learntIds.filter(x => x !== card.id);
      saveState(); next();
    }

    /* ── SEARCH DICTIONARY SYSTEM ── */
    function searchDict() {
      const query = id('dict-search').value.toLowerCase().trim();
      const filtered = VOCAB.filter(x => 
        x.kanji.includes(query) || 
        x.reading.includes(query) || 
        x.meaning.toLowerCase().includes(query)
      );
      
      id('dict-results-container').innerHTML = filtered.map(x => {
        const isSavedOnActivePage = savedWordRelations.some(r => r.pageId === currentVocabPageId && r.vocabId === x.id);
        return `
          <div class="vocab-item">
            <div>
              <div class="vocab-main">
                <span class="vocab-kanji">${x.kanji}</span>
                <span class="vocab-reading">【${x.reading}】</span>
              </div>
              <div class="vocab-details">
                <span class="vocab-badge">${x.pos}</span>
                <span class="vocab-meaning">${x.meaning}</span>
              </div>
            </div>
            <button class="btn-save-vocab ${isSavedOnActivePage ? 'saved' : ''}" onclick="toggleSaveWord(${x.id}, this)" title="Pin to active workspace page">
              <i class="ti ${isSavedOnActivePage ? 'ti-bookmark-filled' : 'ti-bookmark'}"></i>
            </button>
          </div>
        `;
      }).join('');
    }

    function toggleSaveWord(vId, btnEl) {
      if (!currentVocabPageId) {
        alert('Please create or select a Custom Notebook workspace layout page first.');
        return;
      }
      const matchIndex = savedWordRelations.findIndex(r => r.pageId === currentVocabPageId && r.vocabId === vId);
      if (matchIndex > -1) {
        savedWordRelations.splice(matchIndex, 1);
        btnEl.classList.remove('saved');
        btnEl.innerHTML = `<i class="ti ti-bookmark"></i>`;
      } else {
        savedWordRelations.push({ pageId: currentVocabPageId, vocabId: vId });
        btnEl.classList.add('saved');
        btnEl.innerHTML = `<i class="ti ti-bookmark-filled"></i>`;
      }
      saveRelations();
      if (currentTab === 'myvocab') renderMyVocab();
    }

    /* ── PERSISTENT NOTEBOOK & EDITABLE TITLE ENGINE ── */
    function setNotebookTitleEditing(editingState) {
      isEditingNotebookTitle = editingState;
      renderMyVocab();
    }

    function saveActiveNotebookTitle() {
      const inputElement = id('edit-notebook-title-input');
      if (inputElement) {
        const cleanTitleValue = inputElement.value.trim();
        if (cleanTitleValue) {
          const targetPage = MY_VOCAB_PAGES.find(p => p.id === currentVocabPageId);
          if (targetPage) {
            targetPage.title = cleanTitleValue;
            savePages();
          }
        }
      }
      isEditingNotebookTitle = false;
      renderMyVocab();
    }

    function renderMyVocab() {
      // 1. Render Left Sidebar Navigation Timeline
      const sidebarMenu = id('notebook-pages-list');
      sidebarMenu.innerHTML = MY_VOCAB_PAGES.map(p => {
        const count = savedWordRelations.filter(r => r.pageId === p.id).length;
        return `
          <li>
            <button class="menu-item-btn ${p.id === currentVocabPageId ? 'active' : ''}" onclick="selectNotebookPage('${p.id}')">
              <span>📓 ${escHtml(p.title)}</span>
              <span class="badge">${count}</span>
            </button>
          </li>
        `;
      }).join('');

      // 2. Evaluate Visibility States
      if (!currentVocabPageId || MY_VOCAB_PAGES.length === 0) {
        id('myvocab-empty-state').style.display = 'block';
        id('myvocab-single-page-view').style.display = 'none';
        return;
      }

      id('myvocab-empty-state').style.display = 'none';
      id('myvocab-single-page-view').style.display = 'block';

      const activePage = MY_VOCAB_PAGES.find(p => p.id === currentVocabPageId);
      if (!activePage) return;

      // 3. Render Dashboard Title Section with design reference template structure
      const titleWrapper = id('notebook-interactive-title-container');
      if (isEditingNotebookTitle) {
        titleWrapper.innerHTML = `
          <div class="title-edit-container">
            <input type="text" id="edit-notebook-title-input" class="title-edit-input" value="${escHtml(activePage.title)}">
            <button onclick="saveActiveNotebookTitle()" class="title-save-btn">Save</button>
            <button onclick="setNotebookTitleEditing(false)" class="title-cancel-btn">Cancel</button>
          </div>
        `;
        setTimeout(() => id('edit-notebook-title-input').focus(), 50);
      } else {
        titleWrapper.innerHTML = `
          <div class="title-display-container">
            <h3 class="title-display-text">📓 ${escHtml(activePage.title)}</h3>
            <button onclick="setNotebookTitleEditing(true)" class="title-edit-btn" title="Edit Notebook Title">
              <i class="ti ti-pencil"></i> Edit
            </button>
          </div>
        `;
      }

      // 4. Render Bookmarked Custom Vocabulary Tags
      const pageWordIds = savedWordRelations.filter(r => r.pageId === currentVocabPageId).map(r => r.vocabId);
      const pageWordsGrid = id('page-words-grid');
      
      if (pageWordIds.length === 0) {
        pageWordsGrid.innerHTML = `<div style="grid-column: 1/-1; color: var(--blue-4); font-size: 0.9rem; padding: 0.5rem 0;">No pinned words here yet. Use the dictionary panel to collect cards.</div>`;
      } else {
        const matchedWords = VOCAB.filter(x => pageWordIds.includes(x.id));
        pageWordsGrid.innerHTML = matchedWords.map(w => `
          <div class="saved-word-tag">
            <div class="saved-word-info">
              <span class="saved-word-kanji">${w.kanji}</span>
              <span class="saved-word-reading">${w.reading}</span>
            </div>
            <button class="btn-remove-tag" onclick="removeWordRelation('${w.id}')" title="Unpin item">
              <i class="ti ti-x"></i>
            </button>
          </div>
        `).join('');
      }

      // 5. Build and Populate Rich Content Stack Notes modules
      renderNotebookNotesOnly();
    }

    function selectNotebookPage(pId) {
      currentVocabPageId = pId;
      isEditingNotebookTitle = false; // Reset toggle
      renderMyVocab();
    }

    function addNotebookPage() {
      const promptTitle = prompt('Enter a title name for your custom N3 Notebook page context:', 'New Study Canvas');
      if (!promptTitle || !promptTitle.trim()) return;
      const newPageId = 'canvas_' + Date.now();
      MY_VOCAB_PAGES.push({ id: newPageId, title: promptTitle.trim() });
      savePages();
      selectNotebookPage(newPageId);
    }

    function removeWordRelation(vId) {
      savedWordRelations = savedWordRelations.filter(r => !(r.pageId === currentVocabPageId && r.vocabId == vId));
      saveRelations();
      renderMyVocab();
    }

    /* ── NOTE BLOCKS CONTROLLER ── */
    function addNote() {
      if (!currentVocabPageId) return;
      const newNote = {
        id: Date.now(),
        pageId: currentVocabPageId,
        title: 'Note Entry Concept Block',
        body: '',
        expanded: true
      };
      NOTES.push(newNote);
      saveNotes();
      renderNotebookNotesOnly(); // Renders the inner block stack without touching page title visibility states
    }

    function deleteNote(nid) {
      if (!confirm('Are you sure you want to remove this text note block module?')) return;
      NOTES = NOTES.filter(x => x.id !== nid);
      saveNotes();
      renderNotebookNotesOnly();
    }

    function renderNotebookNotesOnly() {
      const container = id('page-notes-container');
      const filteredNotes = NOTES.filter(x => x.pageId === currentVocabPageId);
      
      if (filteredNotes.length === 0) {
        container.innerHTML = `
          <div style="text-align:center; padding: 2rem; color: var(--blue-4); border: 2px dashed var(--blue-2); border-radius: var(--border-radius-md);">
            <p style="margin:0; font-size:0.9rem;">No custom annotation notes active on this workspace deck yet.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = filteredNotes.map(n => `
        <div class="note-card">
          <div class="note-header">
            <div class="note-header-left" onclick="toggleNoteAccordion(${n.id})">
              <i class="ti ${n.expanded ? 'ti-chevron-down' : 'ti-chevron-right'}"></i>
              <span data-note-header-span="${n.id}">${escHtml(n.title || 'Note Block')}</span>
            </div>
            <div class="note-header-actions">
              <button class="btn-note-action" onclick="deleteNote(${n.id})" title="Delete entry block"><i class="ti ti-trash"></i></button>
            </div>
          </div>
          ${n.expanded ? `
            <div class="note-content-area">
              <input type="text" class="note-editable-title" value="${escHtml(n.title)}" placeholder="Edit block header label..." oninput="updateNoteHeaderText(${n.id}, this.value)">
              <div style="height:1px; background-color:var(--blue-2); margin:0.25rem 0 0.75rem 0;"></div>
              <div class="note-body-editor" contenteditable="true" data-placeholder="Type grammar examples, memory notes or context rules here..." oninput="updateNoteContentBody(${n.id}, this)">${n.body}</div>
            </div>
          ` : ''}
        </div>
      `).join('');
    }

    function toggleNoteAccordion(nid) {
      const targetNote = NOTES.find(x => x.id === nid);
      if (targetNote) {
        targetNote.expanded = !targetNote.expanded;
        saveNotes();
        renderNotebookNotesOnly();
      }
    }

    function updateNoteHeaderText(nid, value) {
      const targetNote = NOTES.find(x => x.id === nid);
      if (targetNote) {
        targetNote.title = value;
        saveNotes();
        const innerHeaderSpan = document.querySelector(`[data-note-header-span="${nid}"]`);
        if (innerHeaderSpan) innerHeaderSpan.textContent = value || 'Note Block';
      }
    }

    function updateNoteContentBody(nid, divElement) {
      const targetNote = NOTES.find(x => x.id === nid);
      if (targetNote) {
        targetNote.body = divElement.innerHTML;
        saveNotes();
      }
    }

    function escHtml(s) {
      return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    /* ── RUNTIME ENGINE ACTIVATION INITIALIZATION ── */
    window.addEventListener('DOMContentLoaded', () => {
      loadState();
      switchTab('home');
    });

    /* KEYBOARD HOTKEY SHIFT LISTENER CONTROLS */
    document.addEventListener('keydown', e => {
      if (currentTab === 'study') {
        if (e.key === 'ArrowRight') next();
        else if (e.key === 'ArrowLeft') prev();
        else if (e.key === ' ') { e.preventDefault(); flip(); }
        else if (e.key === 'Enter') markLearnt();
        else if (e.key === 'h' || e.key === 'H') markHard();
      }
    });
  </script>
</body>
</html>
