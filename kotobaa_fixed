<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JLPT N3 Vocabulary Study Tool</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    :root {
      --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;

      /* ── Blue palette (lightest → deepest) ── */
      --blue-0: #F0F6FF;   /* near-white tint — page background */
      --blue-1: #D6E8F7;   /* very light blue — secondary backgrounds */
      --blue-2: #B8D5EE;   /* soft blue — borders, dividers */
      --blue-3: #8BBDE0;   /* medium-light — progress track, hover bg */
      --blue-4: #5A9FD0;   /* mid blue — badge bg, muted labels */
      --blue-5: #2C7EC0;   /* core blue — active tabs, accents */
      --blue-6: #1056A0;   /* deep blue — primary text on cards, CTAs */
      --blue-7: #0A3578;   /* navy — headings, kanji, darkest text */

      --color-background-primary: #ffffff;
      --border-radius-sm: 6px;
      --border-radius-md: 10px;
      --border-radius-lg: 16px;
      
      --shadow-sm: 0 1px 3px rgba(10,53,120,0.05), 0 1px 2px rgba(10,53,120,0.1);
      --shadow-md: 0 4px 6px -1px rgba(10,53,120,0.08), 0 2px 4px -1px rgba(10,53,120,0.04);
      --shadow-lg: 0 10px 15px -3px rgba(10,53,120,0.08), 0 4px 6px -2px rgba(10,53,120,0.04);
      --transition-base: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 0;
      font-family: var(--font-sans);
      background-color: var(--blue-0);
      color: var(--blue-7);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    /* ── App Layout Headers ── */
    .app-header {
      background-color: #ffffff;
      border-bottom: 1px solid var(--blue-2);
      padding: 1rem 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow-sm);
    }
    .header-content {
      max-width: 1000px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .logo-area {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .logo-icon {
      background: linear-gradient(135deg, var(--blue-5), var(--blue-6));
      color: #ffffff;
      width: 40px;
      height: 40px;
      border-radius: var(--border-radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      box-shadow: 0 4px 10px rgba(44,126,192,0.25);
    }
    h1 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--blue-7);
      letter-spacing: -0.01em;
    }

    /* Nav Tabs Navigation */
    .nav-tabs {
      display: flex;
      gap: 0.375rem;
      background-color: var(--blue-0);
      padding: 0.375rem;
      border-radius: var(--border-radius-md);
      border: 1px solid var(--blue-2);
    }
    .tab-btn {
      background: none;
      border: none;
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--blue-4);
      cursor: pointer;
      border-radius: var(--border-radius-sm);
      transition: var(--transition-base);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .tab-btn:hover {
      color: var(--blue-6);
      background-color: rgba(44,126,192,0.08);
    }
    .tab-btn.active {
      background-color: #ffffff;
      color: var(--blue-6);
      box-shadow: var(--shadow-sm);
    }

    .main-container {
      max-width: 1000px;
      margin: 2rem auto;
      padding: 0 1.5rem;
    }

    /* ── Component Cards Visual Styles ── */
    .card {
      background-color: #ffffff;
      border-radius: var(--border-radius-lg);
      border: 1px solid var(--blue-2);
      box-shadow: var(--shadow-md);
      padding: 2rem;
      margin-bottom: 2rem;
    }
    .welcome-card {
      background: linear-gradient(135deg, #ffffff, var(--blue-0));
      border-left: 5px solid var(--blue-5);
    }
    .welcome-card h2 { margin-top:0; color: var(--blue-7); }
    
    .btn-learn {
      background-color: var(--blue-5);
      color: #ffffff;
      border: none;
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
      font-weight: 600;
      border-radius: var(--border-radius-md);
      cursor: pointer;
      transition: var(--transition-base);
      box-shadow: 0 4px 12px rgba(44,126,192,0.2);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-learn:hover {
      background-color: var(--blue-6);
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(16,86,160,0.3);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .stat-card {
      background-color: #ffffff;
      border: 1px solid var(--blue-2);
      border-radius: var(--border-radius-md);
      padding: 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: var(--shadow-sm);
    }
    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--border-radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    .stat-icon.blue { background-color: rgba(44,126,192,0.1); color: var(--blue-5); }
    .stat-icon.green { background-color: rgba(16,185,129,0.1); color: #10B981; }
    .stat-icon.orange { background-color: rgba(245,158,11,0.1); color: #F59E0B; }
    .stat-val { font-size: 1.5rem; font-weight: 700; color: var(--blue-7); line-height: 1.2; }
    .stat-lbl { font-size: 0.85rem; color: var(--blue-4); font-weight: 500; }

    /* ── Flashcard Engine Layout ── */
    .flashcard-wrapper {
      perspective: 1000px;
      max-width: 500px;
      margin: 2rem auto;
    }
    .flashcard {
      width: 100%;
      height: 320px;
      position: relative;
      transform-style: preserve-3d;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
    }
    .flashcard.flipped { transform: rotateY(180deg); }
    .card-face {
      position: absolute;
      width: 100%;
      height: 100%;
      backface-visibility: hidden;
      border-radius: var(--border-radius-lg);
      border: 2px solid var(--blue-2);
      box-shadow: var(--shadow-lg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 2rem;
      text-align: center;
    }
    .card-front { background-color: #ffffff; color: var(--blue-7); }
    .card-back { background-color: var(--blue-0); color: var(--blue-7); transform: rotateY(180deg); border-color: var(--blue-3); }
    .card-kanji { font-size: 3.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--blue-7); }
    .card-reading { font-size: 1.5rem; color: var(--blue-5); font-weight: 600; margin-bottom: 1.5rem; }
    .card-meaning { font-size: 1.6rem; font-weight: 700; color: var(--blue-6); margin-bottom: 0.5rem; }
    .card-pos { font-size: 0.85rem; text-transform: uppercase; background-color: var(--blue-2); color: var(--blue-7); padding: 0.25rem 0.75rem; border-radius: 999px; font-weight: 600; letter-spacing: 0.05em; }
    .card-hint { position: absolute; bottom: 1rem; font-size: 0.85rem; color: var(--blue-4); display: flex; align-items: center; gap: 0.25rem; }
    
    .controls { display: flex; justify-content: center; gap: 1rem; margin-top: 2rem; }
    .btn-action {
      background-color: #ffffff;
      border: 1px solid var(--blue-2);
      color: var(--blue-6);
      padding: 0.75rem 1.25rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: var(--border-radius-md);
      cursor: pointer;
      transition: var(--transition-base);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      box-shadow: var(--shadow-sm);
    }
    .btn-action:hover { border-color: var(--blue-4); background-color: var(--blue-0); color: var(--blue-7); }
    .btn-action.primary { background-color: var(--blue-5); color: #ffffff; border: none; }
    .btn-action.primary:hover { background-color: var(--blue-6); }
    .btn-action.success { color: #10B981; }
    .btn-action.success:hover { background-color: rgba(16,185,129,0.05); border-color: #10B981; }
    .btn-action.warning { color: #F59E0B; }
    .btn-action.warning:hover { background-color: rgba(245,158,11,0.05); border-color: #F59E0B; }
    
    .progress-container { max-width: 500px; margin: 1.5rem auto 0 auto; }
    .progress-bar-track { background-color: var(--blue-2); height: 6px; border-radius: 999px; overflow: hidden; }
    .progress-bar-fill { background: linear-gradient(90deg, var(--blue-4), var(--blue-5)); height: 100%; width: 0%; transition: width 0.3s ease; }
    .progress-txt { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--blue-4); font-weight: 600; margin-top: 0.5rem; }

    /* ── Search & Dictionary ── */
    .search-wrapper { position: relative; margin-bottom: 2rem; }
    .search-input {
      width: 100%;
      padding: 1rem 1.25rem 1rem 3rem;
      font-size: 1.05rem;
      border: 1px solid var(--blue-2);
      border-radius: var(--border-radius-lg);
      color: var(--blue-7);
      background-color: #ffffff;
      box-shadow: var(--shadow-md);
      outline: none;
      transition: var(--transition-base);
    }
    .search-input:focus { border-color: var(--blue-5); box-shadow: 0 0 0 4px rgba(44,126,192,0.15); }
    .search-icon { position: absolute; left: 1.25rem; top: 50%; transform: translateY(-50%); color: var(--blue-4); font-size: 1.25rem; }
    
    .vocab-list { display: flex; flex-direction: column; gap: 1rem; }
    .vocab-item {
      background-color: #ffffff;
      border: 1px solid var(--blue-2);
      border-radius: var(--border-radius-md);
      padding: 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-base);
    }
    .vocab-item:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); border-color: var(--blue-3); }
    .vocab-main { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
    .vocab-kanji { font-size: 1.5rem; font-weight: 700; color: var(--blue-7); }
    .vocab-reading { font-size: 1rem; color: var(--blue-5); font-weight: 600; }
    .vocab-details { margin-top: 0.25rem; }
    .vocab-meaning { font-size: 0.95rem; color: var(--blue-6); font-weight: 500; }
    .vocab-badge { font-size: 0.75rem; background-color: var(--blue-1); color: var(--blue-6); padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: 600; margin-right: 0.5rem; }
    
    .btn-save-vocab { background: none; border: 1px solid var(--blue-2); color: var(--blue-4); width: 36px; height: 36px; border-radius: var(--border-radius-sm); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: var(--transition-base); }
    .btn-save-vocab:hover { color: var(--blue-5); background-color: var(--blue-0); border-color: var(--blue-3); }
    .btn-save-vocab.saved { color: #ffffff; background-color: var(--blue-5); border-color: var(--blue-5); }

    /* ── Notebook Workspace (Visual Alignment) ── */
    .notebook-layout { display: grid; grid-template-columns: 260px 1fr; gap: 2rem; }
    @media(max-width: 768px) { .notebook-layout { grid-template-columns: 1fr; } }
    
    .notebook-sidebar { background-color: #ffffff; border: 1px solid var(--blue-2); border-radius: var(--border-radius-lg); padding: 1rem; box-shadow: var(--shadow-sm); height: fit-content; }
    .sidebar-title { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; color: var(--blue-4); letter-spacing: 0.05em; padding: 0.5rem; margin: 0 0 0.5rem 0; }
    .notebook-menu { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
    
    .menu-item-btn { width: 100%; text-align: left; background: none; border: none; padding: 0.75rem; font-size: 0.95rem; font-weight: 600; color: var(--blue-6); cursor: pointer; border-radius: var(--border-radius-sm); display: flex; align-items: center; justify-content: space-between; transition: var(--transition-base); }
    .menu-item-btn:hover { background-color: var(--blue-0); color: var(--blue-7); }
    .menu-item-btn.active { background-color: var(--blue-5); color: #ffffff; }
    .menu-item-btn .badge { font-size: 0.75rem; background-color: var(--blue-1); color: var(--blue-6); padding: 0.15rem 0.4rem; border-radius: 999px; }
    .menu-item-btn.active .badge { background-color: rgba(255,255,255,0.2); color: #ffffff; }
    
    .btn-add-page { width: 100%; margin-top: 0.75rem; background: none; border: 1px dashed var(--blue-3); color: var(--blue-5); padding: 0.6rem; font-size: 0.85rem; font-weight: 600; border-radius: var(--border-radius-sm); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.375rem; transition: var(--transition-base); }
    .btn-add-page:hover { background-color: var(--blue-0); border-style: solid; border-color: var(--blue-5); }
    
    .notebook-body { background-color: #ffffff; border: 1px solid var(--blue-2); border-radius: var(--border-radius-lg); padding: 2rem; box-shadow: var(--shadow-md); position: relative; }
    
    /* Elegant Title Header Layout (From reference images) */
    .title-display-container { display: flex; align-items: center; gap: 10px; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--blue-1); }
    .title-display-text { font-size: 22px; font-weight: 700; color: var(--blue-7); margin: 0; }
    .title-edit-btn { background: none; border: none; color: var(--blue-4); cursor: pointer; padding: 4px 8px; border-radius: var(--border-radius-sm); transition: var(--transition-base); display: inline-flex; align-items: center; font-size: 14px; font-weight: 600; gap: 4px; }
    .title-edit-btn:hover { color: var(--blue-6); background-color: var(--blue-0); }
    
    /* Clean Title Input State layout */
    .title-edit-container { display: flex; align-items: center; gap: 8px; margin-bottom: 1.5rem; width: 100%; }
    .title-edit-input { flex: 1; font-size: 18px; font-weight: 600; color: var(--blue-7); padding: 6px 12px; border: 2px solid var(--blue-5); border-radius: var(--border-radius-sm); background: #ffffff; outline: none; box-shadow: 0 0 0 3px rgba(44,126,192,0.12); }
    .title-save-btn { background-color: var(--blue-5); color: white; border: none; padding: 8px 16px; font-weight: 600; border-radius: var(--border-radius-sm); cursor: pointer; transition: var(--transition-base); }
    .title-save-btn:hover { background-color: var(--blue-6); }
    .title-cancel-btn { background-color: var(--blue-1); color: var(--blue-6); border: none; padding: 8px 16px; font-weight: 600; border-radius: var(--border-radius-sm); cursor: pointer; transition: var(--transition-base); }
    .title-cancel-btn:hover { background-color: var(--blue-2); }

    /* Notes Blocks & Stack Content Modules */
    .notes-stack { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
    .note-card { border: 1px solid var(--blue-2); border-radius: var(--border-radius-md); overflow: hidden; box-shadow: var(--shadow-sm); background-color: #ffffff; }
    .note-header { background-color: var(--blue-0); padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--blue-2); cursor: pointer; user-select: none; }
    .note-header-left { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: var(--blue-7); }
    .btn-note-action { background: none; border: none; color: var(--blue-4); cursor: pointer; padding: 0.25rem; border-radius: 4px; display: flex; align-items: center; justify-content: center; transition: var(--transition-base); }
    .btn-note-action:hover { color: #EF4444; background-color: #FEE2E2; }
    
    .note-content-area { padding: 1.25rem; }
    .note-editable-title { border: none; outline: none; font-size: 1.05rem; font-weight: 600; color: var(--blue-7); width: 100%; background: transparent; padding: 0.25rem 0; border-bottom: 1px dashed transparent; margin-bottom: 0.75rem; }
    .note-editable-title:focus { border-bottom-color: var(--blue-4); background-color: var(--blue-0); padding-left: 4px; border-radius: 2px; }
    .note-body-editor { min-height: 100px; outline: none; font-size: 0.95rem; color: #334155; line-height: 1.6; }
    .note-body-editor[data-placeholder]:empty:before { content: attr(data-placeholder); color: #94a3b8; }

    .vocab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--blue-2); padding-bottom: 1.5rem; }
    .saved-word-tag { background-color: var(--blue-0); border: 1px solid var(--blue-2); padding: 0.75rem 1rem; border-radius: var(--border-radius-md); display: flex; justify-content: space-between; align-items: center; transition: var(--transition-base); }
    .saved-word-tag:hover { border-color: var(--blue-4); background-color: #ffffff; }
    .saved-word-info { display: flex; flex-direction: column; }
    .saved-word-kanji { font-weight: 700; font-size: 1.1rem; color: var(--blue-7); }
    .saved-word-reading { font-size: 0.85rem; color: var(--blue-5); font-weight: 500; }
    .btn-remove-tag { background: none; border: none; color: var(--blue-3); cursor: pointer; padding: 0.2rem; border-radius: 4px; display: flex; align-items: center; justify-content: center; transition: var(--transition-base); }
    .btn-remove-tag:hover { color: #EF4444; background-color: #FEE2E2; }
    
    .empty-state { text-align: center; padding: 3rem 1rem; color: var(--blue-4); }
    .empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; color: var(--blue-3); }
    .btn-secondary { background-color: #ffffff; border: 1px solid var(--blue-2); color: var(--blue-6); padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600; border-radius: var(--border-radius-sm); cursor: pointer; transition: var(--transition-base); display: inline-flex; align-items: center; gap: 0.375rem; }
    .btn-secondary:hover { background-color: var(--blue-0); border-color: var(--blue-4); }
  </style>
</head>
<body>

  <header class="app-header">
    <div class="header-content">
      <div class="logo-area">
        <div class="logo-icon"><i class="ti ti-book-2"></i></div>
        <h1>JLPT N3 Vocabulary</h1>
      </div>
      <nav class="nav-tabs">
        <button class="tab-btn active" id="tab-home" onclick="switchTab('home')"><i class="ti ti-smart-home"></i> Home</button>
        <button class="tab-btn" id="tab-study" onclick="switchTab('study')"><i class="ti ti-cards"></i> Study</button>
        <button class="tab-btn" id="tab-dict" onclick="switchTab('dict')"><i class="ti ti-search"></i> Dictionary</button>
        <button class="tab-btn" id="tab-myvocab" onclick="switchTab('myvocab')"><i class="ti ti-notebook"></i> My Vocab</button>
      </nav>
    </div>
  </header>

  <main class="main-container">
    <div id="view-home" class="tab-view">
      <div class="card welcome-card">
        <h2>Mimikara Omoeru N3 Study Stream</h2>
        <p>Track, learn, and test your vocabulary performance with items directly loaded from your official N3 training sheet entries.</p>
        <button class="btn-learn" onclick="switchTab('study')">Start Active Flashcards <i class="ti ti-arrow-right"></i></button>
      </div>
      <div class="grid-2">
        <div class="stat-card">
          <div class="stat-icon blue"><i class="ti ti-cards"></i></div>
          <div>
            <div class="stat-val" id="stat-total-cards">0</div>
            <div class="stat-lbl">Loaded Mimikara Words</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="ti ti-circle-check"></i></div>
          <div>
            <div class="stat-val" id="stat-learnt-cards">0</div>
            <div class="stat-lbl">Mastered Terms</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange"><i class="ti ti-bookmark"></i></div>
          <div>
            <div class="stat-val" id="stat-saved-words">0</div>
            <div class="stat-lbl">Pinned in Notebooks</div>
          </div>
        </div>
      </div>
    </div>

    <div id="view-study" class="tab-view" style="display:none;">
      <div class="flashcard-wrapper">
        <div class="flashcard" id="flashcard-element" onclick="flip()">
          <div class="card-face card-front">
            <div class="card-kanji" id="fc-kanji">--</div>
            <div class="card-reading" id="fc-reading">--</div>
            <div class="card-hint"><i class="ti ti-rotate"></i> Click block to reveal definition</div>
          </div>
          <div class="card-face card-back">
            <div class="card-meaning" id="fc-meaning">--</div>
            <div class="card-pos" id="fc-pos">--</div>
            <div class="card-hint"><i class="ti ti-rotate"></i> Click block to reveal term</div>
          </div>
        </div>
        <div class="progress-container">
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="study-progress-fill"></div>
          </div>
          <div class="progress-txt">
            <span id="study-progress-lbl">Card 0 of 0</span>
            <span id="study-percent-lbl">0% Mastered</span>
          </div>
        </div>
        <div class="controls">
          <button class="btn-action" onclick="prev()"><i class="ti ti-chevron-left"></i> Back</button>
          <button class="btn-action warning" onclick="markHard()"><i class="ti ti-alert-circle"></i> Review Later</button>
          <button class="btn-action success" onclick="markLearnt()"><i class="ti ti-circle-check"></i> Mastered</button>
          <button class="btn-action primary" onclick="next()">Next <i class="ti ti-chevron-right"></i></button>
        </div>
      </div>
    </div>

    <div id="view-dict" class="tab-view" style="display:none;">
      <div class="search-wrapper">
